{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "obsidian": {
      "command": "npx",
      "args": [
        "-y",
        "seekstone"
      ],
      "env": {
        "SEEKSTONE_VAULT": "/home/bobby/obsidian-vault"
      },
      "enabled": true
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless"
      ],
      "enabled": true
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "enabled": true
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "[REDACTED]"
      },
      "enabled": true
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/bobby/.openclaw/workspace",
        "/home/bobby/obsidian-vault",
        "/home/bobby"
      ],
      "enabled": true
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true
    }
  },
  "groups": {
    "research": [
      "context7",
      "fetch",
      "playwright"
    ],
    "knowledge": [
      "obsidian",
      "memory",
      "filesystem"
    ],
    "dev": [
      "github",
      "sequential-thinking"
    ]
  },
  "users": [
    {
      "username": "admin",
      "password": "$2b$10$Vt7krIvjNgyN67LXqly0uOcTpN0LI55cYRbcKC71pUDAP0nJ7RPa.",
      "isAdmin": true
    }
  ],
  "systemConfig": {
    "routing": {
      "enableBearerAuth": false,
      "skipAuth": true
    },
    "smartRouting": {
      "enabled": true,
      "embeddingProvider": "openai",
      "openaiApiBaseUrl": "https://integrate.api.nvidia.com/v1",
      "openaiApiKey": "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",
      "openaiApiEmbeddingModel": "nvidia/nv-embedqa-e5-v5",
      "embeddingDimensions": 1024,
      "relevanceThreshold": 0.3
    },
    "oauthServer": {
      "enabled": true,
      "accessTokenLifetime": 3600,
      "refreshTokenLifetime": 1209600,
      "authorizationCodeLifetime": 300,
      "requireClientSecret": false,
      "allowedScopes": [
        "read",
